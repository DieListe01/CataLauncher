                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="42" Height="42" Background="#D84D2B" CornerRadius="21" HorizontalAlignment="Left">
                                                <TextBlock Text="C" Foreground="#FFF8E9" FontFamily="Bahnschrift SemiBold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border x:Name="InstallationCatanTopBadge" Grid.Column="2" Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource Brush.BadgeNeutral}" BorderBrush="#C7AC84" BorderThickness="1" Margin="0" VerticalAlignment="Center" Visibility="Collapsed">
