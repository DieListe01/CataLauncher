                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{StaticResource Brush.Inset}" BorderBrush="{StaticResource Brush.InsetBorder}" BorderThickness="1" CornerRadius="18" Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="42" Height="42" Background="#6AA25D" CornerRadius="21" HorizontalAlignment="Left">
                                                    <TextBlock Text="R" Foreground="#FFF8E9" FontFamily="Bahnschrift SemiBold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Border x:Name="InstallationRadminTopBadge" Grid.Column="2" Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource Brush.BadgeNeutral}" BorderBrush="#C7AC84" BorderThickness="1" Margin="0" VerticalAlignment="Center" Visibility="Collapsed">
                                                    <TextBlock x:Name="InstallationRadminTopBadgeText" Foreground="#6A4D2C" FontFamily="Bahnschrift SemiBold" FontSize="11" />
                                                </Border>
                                            </Grid>

                                            <TextBlock Grid.Row="1" Text="Radmin VPN" Margin="0,14,0,0" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource Brush.Text}" />
                                            <TextBlock Grid.Row="2" Text="Virtuelles LAN fuer Internet-Multiplayer" Margin="0,6,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="12.5" />
                                            <TextBlock Grid.Row="3" Text="Radmin VPN erstellt ein virtuelles LAN ueber das Internet. Damit koennen Spieler so verbunden werden, als waeren sie im selben lokalen Netzwerk." Margin="0,14,0,0" Foreground="{StaticResource Brush.Text}" FontSize="12.5" TextWrapping="Wrap" />

                                            <StackPanel Grid.Row="4" Margin="0,16,0,0">
                                                <TextBlock Text="Pfad" Foreground="{StaticResource Brush.TextMuted}" FontSize="11.5" />
                                                <Border Background="#FFF7EE" BorderBrush="{StaticResource Brush.InsetBorder}" BorderThickness="1" CornerRadius="12" Padding="12,9" Margin="0,6,0,0">
                                                    <TextBlock x:Name="InstallationRadminPathText" Text="lade..." Foreground="{StaticResource Brush.Text}" FontSize="12.5" TextWrapping="Wrap" FontFamily="Consolas" />
                                                </Border>

                                                <TextBlock Text="Versionsstatus" Foreground="{StaticResource Brush.TextMuted}" FontSize="11.5" Margin="0,12,0,0" />
                                                <Border Background="#FFF7EE" BorderBrush="{StaticResource Brush.InsetBorder}" BorderThickness="1" CornerRadius="12" Padding="12,9" Margin="0,6,0,0">
                                                    <Grid>
                                                        <TextBlock x:Name="InstallationRadminVersionText" Text="installiert: pruefe... | online: pruefe..." Margin="0,0,80,0" Foreground="{StaticResource Brush.Text}" FontSize="12.5" TextWrapping="Wrap" />
                                                        <Border x:Name="InstallationRadminVersionBadge" Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource Brush.BadgeNeutral}" BorderBrush="#C7AC84" BorderThickness="1" Padding="8,3" Margin="0" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                                                            <TextBlock x:Name="InstallationRadminVersionBadgeText" Foreground="#6A4D2C" FontFamily="Bahnschrift SemiBold" FontSize="10.5" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>

                                            <Border Grid.Row="5" Background="#F3E7D6" BorderBrush="#DEBF91" BorderThickness="1" CornerRadius="12" Padding="12,10" Margin="0,16,0,0">
                                                <TextBlock x:Name="InstallationRadminHintText" Text="Lokale Installation wird geprueft..." Foreground="#7A5B3F" TextWrapping="Wrap" FontSize="12" />
                                            </Border>

                                            <WrapPanel Grid.Row="6" Margin="0,16,0,0">
                                                <Button Width="126" Style="{StaticResource MicroButtonStyle}" Content="Website" Click="OpenRadminWebsiteButton_Click" />
                                                <Button x:Name="InstallationRadminOpenButton" Width="132" Margin="10,0,0,0" Style="{StaticResource MicroButtonStyle}" Content="Tool oeffnen" Click="OpenRadminButton_Click" />
                                                <Button x:Name="InstallationRadminUpdateButton" Width="132" Margin="10,0,0,0" Style="{StaticResource MiniPrimaryButtonStyle}" Content="Update holen" Click="RadminPatchButton_Click" Visibility="Collapsed" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Background="{StaticResource Brush.Inset}" BorderBrush="{StaticResource Brush.InsetBorder}" BorderThickness="1" CornerRadius="18" Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="42" Height="42" Background="#C88E3C" CornerRadius="21" HorizontalAlignment="Left">
                                                    <TextBlock Text="D" Foreground="#FFF8E9" FontFamily="Bahnschrift SemiBold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Border x:Name="InstallationDgVoodooTopBadge" Grid.Column="2" Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource Brush.BadgeNeutral}" BorderBrush="#C7AC84" BorderThickness="1" Margin="0" VerticalAlignment="Center" Visibility="Collapsed">
                                                    <TextBlock x:Name="InstallationDgVoodooTopBadgeText" Foreground="#6A4D2C" FontFamily="Bahnschrift SemiBold" FontSize="11" />
                                                </Border>
                                            </Grid>

                                            <TextBlock Grid.Row="1" Text="dgVoodoo2" Margin="0,14,0,0" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource Brush.Text}" />
                                            <TextBlock Grid.Row="2" Text="Kompatibilitaet fuer aeltere Grafik-APIs" Margin="0,6,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="12.5" />
                                            <TextBlock Grid.Row="3" Text="dgVoodoo2 hilft dabei, aeltere DirectX- und Glide-Spiele auf modernen Windows-Systemen stabiler und kompatibler auszufuehren." Margin="0,14,0,0" Foreground="{StaticResource Brush.Text}" FontSize="12.5" TextWrapping="Wrap" />

                                            <StackPanel Grid.Row="4" Margin="0,16,0,0">
                                                <TextBlock Text="Pfad" Foreground="{StaticResource Brush.TextMuted}" FontSize="11.5" />
                                                <Border Background="#FFF7EE" BorderBrush="{StaticResource Brush.InsetBorder}" BorderThickness="1" CornerRadius="12" Padding="12,9" Margin="0,6,0,0">
                                                    <TextBlock x:Name="InstallationDgVoodooPathText" Text="lade..." Foreground="{StaticResource Brush.Text}" FontSize="12.5" TextWrapping="Wrap" FontFamily="Consolas" />
                                                </Border>

                                                <TextBlock Text="Versionsstatus" Foreground="{StaticResource Brush.TextMuted}" FontSize="11.5" Margin="0,12,0,0" />
                                                <Border Background="#FFF7EE" BorderBrush="{StaticResource Brush.InsetBorder}" BorderThickness="1" CornerRadius="12" Padding="12,9" Margin="0,6,0,0">
                                                    <Grid>
                                                        <TextBlock x:Name="InstallationDgVoodooVersionText" Text="installiert: pruefe... | online: pruefe..." Margin="0,0,80,0" Foreground="{StaticResource Brush.Text}" FontSize="12.5" TextWrapping="Wrap" />
                                                        <Border x:Name="InstallationDgVoodooVersionBadge" Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource Brush.BadgeNeutral}" BorderBrush="#C7AC84" BorderThickness="1" Padding="8,3" Margin="0" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                                                            <TextBlock x:Name="InstallationDgVoodooVersionBadgeText" Foreground="#6A4D2C" FontFamily="Bahnschrift SemiBold" FontSize="10.5" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>

                                            <Border Grid.Row="5" Background="#F3E7D6" BorderBrush="#DEBF91" BorderThickness="1" CornerRadius="12" Padding="12,10" Margin="0,16,0,0">
                                                <TextBlock x:Name="InstallationDgVoodooHintText" Text="Lokale Installation wird geprueft..." Foreground="#7A5B3F" TextWrapping="Wrap" FontSize="12" />
                                            </Border>

                                            <WrapPanel Grid.Row="6" Margin="0,16,0,0">
                                                <Button Width="126" Style="{StaticResource MicroButtonStyle}" Content="Website" Click="OpenDgVoodooWebsiteButton_Click" />
                                                <Button x:Name="InstallationDgVoodooOpenButton" Width="132" Margin="10,0,0,0" Style="{StaticResource MicroButtonStyle}" Content="Tool oeffnen" Click="OpenDgVoodooButton_Click" />
                                                <Button x:Name="InstallationDgVoodooUpdateButton" Width="132" Margin="10,0,0,0" Style="{StaticResource MiniPrimaryButtonStyle}" Content="Update holen" Click="DgVoodooPatchButton_Click" Visibility="Collapsed" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="SystemInfoCard" Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" Style="{StaticResource CardBorderStyle}" Margin="0" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Systeminformation" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource Brush.Text}" />
                                <TextBlock Text="Wichtige Systemdaten fuer Diagnose und Kompatibilitaet." Margin="0,6,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="12.5" />

                                <ItemsControl x:Name="SystemInfoItemsControl" Margin="0,18,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="250" CornerRadius="14" Padding="14" Margin="0,0,14,14">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource Brush.Inset}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.InsetBorder}" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding BadgeKind}" Value="warning">
                                                                <Setter Property="Background" Value="#E8D8CB" />
                                                                <Setter Property="BorderBrush" Value="#C6774F" />
                                                                <Setter Property="BorderThickness" Value="2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" VerticalAlignment="Center" />
                                                        <Border Grid.Column="1" Visibility="{Binding BadgeVisibility}" BorderThickness="1" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                                    <Setter Property="Background" Value="{StaticResource Brush.BadgeNeutral}" />
                                                                    <Setter Property="BorderBrush" Value="#C7AC84" />
                                                                    <Setter Property="Visibility" Value="{Binding BadgeVisibility}" />
                                                                    <Setter Property="Padding" Value="8,3" />
                                                                    <Setter Property="Margin" Value="8,0,0,0" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding BadgeKind}" Value="ok">
                                                                            <Setter Property="Background" Value="{StaticResource Brush.BadgeOk}" />
                                                                            <Setter Property="BorderBrush" Value="#7D9A62" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding BadgeKind}" Value="warning">
                                                                            <Setter Property="Background" Value="{StaticResource Brush.BadgeWarning}" />
                                                                            <Setter Property="BorderBrush" Value="#C8923D" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding BadgeText}" FontFamily="Bahnschrift SemiBold" FontSize="10.5">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#6A4D2C" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding BadgeKind}" Value="ok">
                                                                                <Setter Property="Foreground" Value="#486231" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding BadgeKind}" Value="warning">
                                                                                <Setter Property="Foreground" Value="#7A531F" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Value}" Margin="0,8,0,0" Foreground="{StaticResource Brush.Text}" FontFamily="Bahnschrift SemiBold" FontSize="14" TextWrapping="Wrap" />
                                                    <Button Margin="0,12,0,0" HorizontalAlignment="Left" Style="{StaticResource MicroButtonStyle}" Content="{Binding ActionText}" ToolTip="{Binding ActionToolTip}" Visibility="{Binding ActionVisibility}" Click="SystemInfoItemActionButton_Click" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ActionsCard" Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource CardBorderStyle}" Margin="0">
                            <StackPanel>
                                    <TextBlock Text="Aktionen" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource Brush.Text}" />
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Button x:Name="FirewallActionButton" Grid.Row="0" Grid.Column="0" Style="{StaticResource MiniPrimaryButtonStyle}" Content="Ports freigeben" Click="FirewallToggleAction_Click" />
                                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource MiniSecondaryButtonStyle}" Content="Status pruefen" Click="RefreshStatusButton_Click" />

                                        <Button x:Name="RadminStateButton" Grid.Row="2" Grid.Column="0" Style="{StaticResource MiniSecondaryButtonStyle}" Content="Radmin oeffnen" Click="OpenRadminButton_Click" />
                                        <Button x:Name="DgVoodooStateButton" Grid.Row="2" Grid.Column="2" Style="{StaticResource MiniSecondaryButtonStyle}" Content="dgVoodoo2 oeffnen" Click="OpenDgVoodooButton_Click" />
                                    </Grid>

                                    <WrapPanel Margin="0,12,0,0">
                                        <Border Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource Brush.BadgeWarning}" BorderBrush="#D2AC63" BorderThickness="1"><TextBlock x:Name="FirewallBadgeText" Text="Firewall -" Foreground="#865D1C" /></Border>
                                    </WrapPanel>
                                    <TextBlock Text="Ports: TCP 47624 | UDP 2300-2400" Margin="2,8,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="11.5" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border x:Name="LogCard" Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel>
                                <TextBlock Text="Status / Log" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource Brush.Text}" />
                                <Border DockPanel.Dock="Right" Width="34" Height="34" Background="{StaticResource Brush.SecondaryGradient}" BorderBrush="#B48650" BorderThickness="1" CornerRadius="17">
                                    <TextBlock Text="&lt;" Foreground="#5D462E" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Bahnschrift SemiBold" />
                                </Border>
                            </DockPanel>

                            <Border Grid.Row="1" Margin="0,14,0,0" Background="{StaticResource Brush.Log}" BorderBrush="{StaticResource Brush.LogBorder}" BorderThickness="1" CornerRadius="16" Padding="14">
                                <TextBox x:Name="LogTextBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#F6E7D4"
                                         FontFamily="Consolas"
                                         FontSize="12.5"
                                         TextWrapping="Wrap"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
