                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="1" Text="Catan.exe" Margin="0,14,0,0" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource Brush.Text}" />
