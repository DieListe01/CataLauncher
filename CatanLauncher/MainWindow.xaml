                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Startstatus" Foreground="{StaticResource Brush.TextMuted}" FontSize="11.5" />
                                                <Border Background="#FFF7EE" BorderBrush="{StaticResource Brush.InsetBorder}" BorderThickness="1" CornerRadius="12" Padding="12,9" Margin="0,6,0,0">
                                                    <Grid>
                                                        <TextBlock x:Name="InstallationCatanStatusText" Text="lokale Installation wird geprueft..." Margin="0,0,80,0" Foreground="{StaticResource Brush.Text}" FontSize="12.5" TextWrapping="Wrap" />
                                                        <Border x:Name="InstallationCatanStatusBadge" Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource Brush.BadgeNeutral}" BorderBrush="#C7AC84" BorderThickness="1" Padding="8,3" Margin="0" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                                                            <TextBlock x:Name="InstallationCatanStatusBadgeText" Foreground="#6A4D2C" FontFamily="Bahnschrift SemiBold" FontSize="10.5" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="4" Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Background="#F3E7D6" BorderBrush="#DEBF91" BorderThickness="1" CornerRadius="12" Padding="12,10" Margin="0,0,16,0">
                                                <TextBlock x:Name="InstallationCatanHintText" Text="Lokale Installation wird geprueft..." Foreground="#7A5B3F" TextWrapping="Wrap" FontSize="12" />
                                            </Border>

                                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                                <Button x:Name="InstallationCatanStartButton" Width="140" Style="{StaticResource MicroButtonStyle}" Content="Spiel starten" Click="StartCatanOnlyButton_Click" />
                                                <Button Width="132" Margin="10,0,0,0" Style="{StaticResource MicroButtonStyle}" Content="Pfad anpassen" Click="SettingsButton_Click" />
                                            </WrapPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Grid Margin="0,18,0,0">
