<Window x:Class="Catan.WpfLauncher.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher Einstellungen"
        Width="920"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="SettingsCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    Background="#FFF8F0"
                                    BorderBrush="{StaticResource Brush.CardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check"
                                      Data="M 4,9 L 7.2,12 L 13.5,5"
                                      Stroke="#486231"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed" />
                            </Border>

                            <ContentPresenter Grid.Column="1"
                                              Margin="10,0,0,0"
                                              VerticalAlignment="Center" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#FFF3E2" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.BadgeOk}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#7D9A62" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,18,14" />
        </Style>

        <Style x:Key="SettingsInfoBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F3E7D6" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="BorderBrush" Value="#DEBF91" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Brush.WindowGradient}" BorderBrush="#A97542" BorderThickness="1" CornerRadius="18">
        <Grid>
            <Image Source="Assets/catan-die-erste-insel-backround.jpg" Stretch="UniformToFill" Opacity="0.04" />
            <Rectangle Fill="#38FFF7EA" RadiusX="18" RadiusY="18" />

            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="118" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Cursor="SizeAll" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="18" Height="18" CornerRadius="5" Background="#D84D2B" BorderBrush="#7A2C17" BorderThickness="1">
                            <TextBlock Text="C" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
                        </Border>
                        <TextBlock Text="Launcher Einstellungen" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#5A3F28" FontSize="13" FontFamily="Bahnschrift SemiBold" />
                    </StackPanel>

                    <Button Grid.Column="1" Click="CancelButton_Click" Style="{StaticResource WindowChromeButtonStyle}" Background="#E8C7B5" BorderBrush="#B57E65" Content="X" />
                </Grid>

                <Border Grid.Row="1" BorderBrush="#8A6038" BorderThickness="1" CornerRadius="24" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Border.Background>
                        <ImageBrush ImageSource="Assets/catan-die-erste-insel-backround.jpg" Stretch="UniformToFill" AlignmentY="Top" />
                    </Border.Background>

                    <Grid>
                        <Rectangle RadiusX="24" RadiusY="24">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#A6000000" />
                                    <GradientStop Offset="0.45" Color="#62000000" />
                                    <GradientStop Offset="1" Color="#12000000" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <Grid Margin="22,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="LAUNCHER EINSTELLUNGEN" Foreground="{StaticResource Brush.TextSoft}" FontSize="25" FontFamily="Book Antiqua" FontWeight="Bold" />
                                <TextBlock Text="Pfad-Konfiguration fuer Catan, dgVoodoo2, Radmin VPN und Launcher-Musik." Margin="0,7,0,0" Foreground="#F6E7CB" FontSize="13" />
                                <TextBlock Text="Die Werte landen in derselben config.ini wie im bisherigen Launcher, nur mit passenderem WPF-Look." Margin="0,4,0,0" Foreground="#DCC2A0" FontSize="11.5" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Border Style="{StaticResource StatusBadgeStyle}" Background="#3DFFF6E6" BorderBrush="#6BCFBF" BorderThickness="1" Margin="0,0,0,8">
                                    <TextBlock Text="config.ini" Foreground="#ECF8F3" FontFamily="Bahnschrift SemiBold" FontSize="11.5" />
                                </Border>
                                <Border Style="{StaticResource StatusBadgeStyle}" Background="#3FE9DFC9" BorderBrush="#CDB792" BorderThickness="1" Margin="0">
                                    <TextBlock Text="lokale Werte" Foreground="#FFF4E1" FontFamily="Bahnschrift SemiBold" FontSize="11.5" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,16,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.42*" />
                        <ColumnDefinition Width="0.94*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Programme" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource Brush.Text}" />
                            <TextBlock Text="Pflichtfelder fuer Spielstart und Grafik-Setup, Radmin bleibt optional." Margin="0,4,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" />

                            <Grid Margin="0,18,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="148" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="118" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,18,14">
                                    <TextBlock Text="Catan.exe" Style="{StaticResource SettingsLabelStyle}" Margin="0" />
                                    <TextBlock Text="Pflicht" Foreground="{StaticResource Brush.TextMuted}" FontSize="11" />
                                </StackPanel>
                                <TextBox x:Name="CatanPathTextBox" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,12,14" />
                                <Button Grid.Column="2" Style="{StaticResource MicroButtonStyle}" Margin="0,0,0,14" Content="Datei waehlen" Click="BrowseCatanButton_Click" />

                                <StackPanel Grid.Row="1" Margin="0,0,18,14">
                                    <TextBlock Text="dgVoodooCpl.exe" Style="{StaticResource SettingsLabelStyle}" Margin="0" />
                                    <TextBlock Text="Pflicht" Foreground="{StaticResource Brush.TextMuted}" FontSize="11" />
                                </StackPanel>
                                <TextBox x:Name="DgVoodooPathTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,12,14" />
                                <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource MicroButtonStyle}" Margin="0,0,0,14" Content="Datei waehlen" Click="BrowseDgVoodooButton_Click" />

                                <StackPanel Grid.Row="2" Margin="0,0,18,0">
                                    <TextBlock Text="Radmin VPN" Style="{StaticResource SettingsLabelStyle}" Margin="0" />
                                    <TextBlock Text="Optional" Foreground="{StaticResource Brush.TextMuted}" FontSize="11" />
                                </StackPanel>
                                <TextBox x:Name="RadminPathTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,12,0" />
                                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource MicroButtonStyle}" Content="Datei waehlen" Click="BrowseRadminButton_Click" />
                            </Grid>

                            <Border Style="{StaticResource SettingsInfoBorderStyle}" Margin="0,18,0,0">
                                <TextBlock Text="Wenn du Radmin leer laesst, bleiben Netzwerk-Checks erhalten, aber die GUI wird nicht direkt gestartet." Foreground="#7A5B3F" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Audio / Hinweise" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource Brush.Text}" />
                            <TextBlock Text="Launcher-Musik und kurze Hinweise fuer die gespeicherten Einstellungen." Margin="0,4,0,0" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" />

                            <Border Background="{StaticResource Brush.Inset}" BorderBrush="{StaticResource Brush.InsetBorder}" BorderThickness="1" CornerRadius="14" Padding="14,12" Margin="0,18,0,0">
                                <StackPanel>
                                    <CheckBox x:Name="MusicEnabledCheckBox" Style="{StaticResource SettingsCheckBoxStyle}" Content="Hintergrundmusik im Launcher verwenden" />

                                    <Border Background="#26FFF6E6" CornerRadius="14" Padding="12,10" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Musik-Lautstaerke" Foreground="{StaticResource Brush.Text}" FontFamily="Bahnschrift SemiBold" />
                                            <DockPanel Margin="0,10,0,0">
                                                <TextBlock x:Name="MusicVolumeText" DockPanel.Dock="Right" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush.Text}" FontFamily="Bahnschrift SemiBold" />
                                                <Slider x:Name="MusicVolumeSlider" Style="{StaticResource AudioSliderStyle}" Minimum="0" Maximum="100" ValueChanged="MusicVolumeSlider_ValueChanged" Cursor="Hand" />
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsInfoBorderStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Gespeichert in derselben config.ini wie der bisherige WinForms-Launcher." Foreground="#7A5B3F" TextWrapping="Wrap" />
                                    <TextBlock Text="Pfad-Aenderungen wirken nach dem Speichern sofort im Launcher." Margin="0,8,0,0" Foreground="#7A5B3F" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,16,0,0">
                                <Border Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource Brush.BadgeNeutral}" BorderBrush="#C7AC84" BorderThickness="1">
                                    <TextBlock Text="Catan + dgVoodoo2 erforderlich" Foreground="#6A4D2C" FontFamily="Bahnschrift SemiBold" FontSize="11" />
                                </Border>
                                <Border Style="{StaticResource StatusBadgeStyle}" Background="{StaticResource Brush.BadgeOk}" BorderBrush="#7D9A62" BorderThickness="1">
                                    <TextBlock Text="Musik optional" Foreground="#486231" FontFamily="Bahnschrift SemiBold" FontSize="11" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Text="Tipp: Ein Doppelklick auf die Pfadfelder erlaubt auch manuelle Korrekturen ohne Dateidialog." />
                    <Button Grid.Column="1" Width="126" Margin="0,0,12,0" Style="{StaticResource SecondaryButtonStyle}" Content="Abbrechen" Click="CancelButton_Click" />
                    <Button Grid.Column="2" Width="140" Style="{StaticResource PrimaryButtonStyle}" Content="Speichern" Click="SaveButton_Click" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
